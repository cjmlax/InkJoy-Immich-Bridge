# IMPORTANT: this file is read by Docker's env_file, which does NOT support
# inline comments. Keep every comment on its own line. Never put text after a
# value (e.g. "PLAY_ORDER=SHUFFLE   # note") -- the whole right-hand side,
# comment included, becomes the value.

# ---- Immich ----
IMMICH_URL=http://192.168.1.10:2283/api
# scoped key: asset.read, asset.view, asset.download, album.read
IMMICH_API_KEY=paste-immich-key
# source album to mirror
IMMICH_ALBUM_ID=paste-immich-album-uuid
# 0 = pull every photo in the album
MAX_PHOTOS=0
# 'preview' = Immich's JPEG rendition (handles HEIC/RAW, needs asset.view); 'original' = source file
IMMICH_IMAGE_SIZE=preview

# ---- InkJoy (your account; bind the frame in the app once first) ----
INKJOY_BASE=https://openapi.inkjoyframe.com
INKJOY_EMAIL=you@example.com
INKJOY_PASSWORD=your-inkjoy-password
# leave blank to auto-pick the only/first frame, or paste a device ID
INKJOY_DEVICE_ID=
INKJOY_ALBUM_NAME=Immich
TIMEZONE=America/New_York

# ---- Carousel (how the FRAME advances photos) ----
# SHUFFLE or SEQUENTIALLY
PLAY_ORDER=SHUFFLE
# FIXED uses UPDATE_TIMES; INTERVAL uses INTERVAL_MIN + ACTIVE window
UPDATE_TYPE=FIXED
UPDATE_TIMES=08:00,13:00,18:00,22:00
# repeat the schedule every N days (1 = daily)
UPDATE_DAYS=1
INTERVAL_MIN=120
ACTIVE_BEGIN=08:00
ACTIVE_END=22:00
# TRIGGER_ON_DEVICE is gentler on battery; TRIGGER_ON_SERVER if it won't advance
STRATEGY_TYPE=TRIGGER_ON_DEVICE
# 0 = sleep after each play (saves battery), 1 = stay awake
IDLE_AFTER=0

# ---- Image prep ----
# downscale to panel size; no color processing
RESIZE_TO_PANEL=true

# ---- Sync behaviour ----
# Path to the fingerprint file; mount a volume at /data so it survives restarts
STATE_PATH=/data/state.json
# Seconds to pause between uploads (raise to e.g. 0.5 if you hit rate limits)
UPLOAD_DELAY_SEC=0
# true = ignore the fingerprint and re-upload everything once
FORCE_RESYNC=false

# ---- Bridge schedule (how often THIS container refreshes the album) ----
# e.g. 720 = twice a day
SYNC_INTERVAL_MINUTES=720
# true = one sync then exit (for testing / host cron)
RUN_ONCE=false