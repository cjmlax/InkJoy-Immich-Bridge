# ---- Immich ----
IMMICH_URL=http://192.168.1.10:2283/api    # set to proper URL, including /api at the end
IMMICH_API_KEY=paste-immich-key            # scopes: asset.read, asset.view, asset.download, album.read
IMMICH_ALBUM_ID=paste-immich-album-uuid    # source album to mirror
MAX_PHOTOS=30

# ---- InkJoy (your account; bind the frame in the app once first) ----
INKJOY_BASE=https://openapi.inkjoyframe.com #Do not change
INKJOY_EMAIL=you@example.com
INKJOY_PASSWORD=your-inkjoy-password
INKJOY_DEVICE_ID=                          # leave blank to auto-pick the only/first frame
INKJOY_ALBUM_NAME=Immich
TIMEZONE=America/New_York

# ---- Carousel (how the FRAME advances photos) ----
PLAY_ORDER=SHUFFLE                         # SHUFFLE | SEQUENTIALLY
UPDATE_TYPE=FIXED                          # FIXED (UPDATE_TIMES) | INTERVAL (INTERVAL_MIN + window)
UPDATE_TIMES=08:00,13:00,18:00,22:00       # Only used for FIXED update type
INTERVAL_MIN=120                           # Only used for INTERVAL update type
ACTIVE_BEGIN=08:00
ACTIVE_END=22:00
STRATEGY_TYPE=TRIGGER_ON_DEVICE            # device-timed = gentler on battery; TRIGGER_ON_SERVER if it won't advance
IDLE_AFTER=0                               # 0 = sleep after each play (saves battery), 1 = stay awake

# ---- Image prep ----
RESIZE_TO_PANEL=true                       # downscale to panel size; no color processing

# ---- Bridge schedule (how often THIS container refreshes the album) ----
SYNC_INTERVAL_MINUTES=720                  # e.g. 720 = twice a day
RUN_ONCE=false                             # true = one sync then exit (for testing / host cron)
