# ---- Immich ----
# set to proper URL, including /api at the end
IMMICH_URL=http://192.168.1.10:2283/api
# scopes: asset.read, asset.view, asset.download, album.read
IMMICH_API_KEY=paste-immich-key
#source album to mirror
IMMICH_ALBUM_ID=paste-immich-album-uuid
# Maximum nnumber of photos to pull
MAX_PHOTOS=30

# ---- InkJoy (your account; bind the frame in the app once first) ----
# Do not change the base URL, only the usernname and password
INKJOY_BASE=https://openapi.inkjoyframe.com
INKJOY_EMAIL=you@example.com
INKJOY_PASSWORD=your-inkjoy-password
# leave blank to auto-pick the only/first frame
INKJOY_DEVICE_ID=device-ID-here
# Name that the album will have in the app
INKJOY_ALBUM_NAME=Immich
TIMEZONE=America/New_York

# ---- Carousel (how the FRAME advances photos) ----
# SHUFFLE | SEQUENTIALLY
PLAY_ORDER=SHUFFLE
# FIXED (UPDATE_TIMES) | INTERVAL (INTERVAL_MIN + window)
UPDATE_TYPE=FIXED
# Only used for FIXED update type
UPDATE_TIMES=08:00,13:00,18:00,22:00
# Only used for FIXED update type
UPDATE_DAYS=1
# Only used for INTERVAL update type
INTERVAL_MIN=120
ACTIVE_BEGIN=08:00
ACTIVE_END=22:00
# device-timed = gentler on battery; TRIGGER_ON_SERVER if it won't advance
STRATEGY_TYPE=TRIGGER_ON_DEVICE
# 0 = sleep after each play (saves battery), 1 = stay awake
IDLE_AFTER=0

# ---- Image prep ----
# downscale to panel size; no color processing
RESIZE_TO_PANEL=true

# ---- Bridge schedule (how often THIS container refreshes the album) ----
# e.g. 720 = twice a day
SYNC_INTERVAL_MINUTES=720
# true = one sync then exit (for testing / host cron)
RUN_ONCE=false
